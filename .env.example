# PostingHub env example — Phase 2
# 실제 값은 Doppler `postinghub` 프로젝트 / `dev` config 에서.
#
# 권장: `doppler run --project postinghub --config dev -- npm run dev`
# 또는: `npm run env:pull` 로 .env.local 동기화 (gitignored)

# ──────────────────────────────────────────────────────────────────────
# 클라이언트 + 서버 양쪽 노출 OK (VITE_PUBLIC_ 접두어)
# ──────────────────────────────────────────────────────────────────────
VITE_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=ey...

# ──────────────────────────────────────────────────────────────────────
# 서버 전용 (Edge Function / scripts) — 절대 클라이언트 번들 X
# Doppler 에서 dev/stg/prd config 별로 다른 값
# ──────────────────────────────────────────────────────────────────────

# Supabase service role — RLS 우회. Edge Function 내부에서만.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Hook 엔드포인트 (Claude → PostingHub) 공통 Bearer secret.
# 캠페인별 url_token 으로 갈음하려면 hooks 테이블 사용.
HOOK_SHARED_SECRET=phk_dev_xxxxxxxxxxxxxxxx

# D-008: Single-user 자동 sign-in (선택)
# 둘 다 채우면 AuthProvider 가 mount 시 자동 로그인 → /login 화면 안 보임.
# 비워두면 매직링크 흐름 정상 동작 (팀 모드).
VITE_PUBLIC_AUTO_SIGNIN_EMAIL=
VITE_PUBLIC_AUTO_SIGNIN_PASSWORD=
